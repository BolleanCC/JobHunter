{
  "name": "jobhunter",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "tsx apps/cli/src/index.ts",
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx packages/db/src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --build --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "drizzle-kit": "^0.21.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "better-sqlite3": "^9.4.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.30.0",
    "zod": "^3.22.0"
  }
}
